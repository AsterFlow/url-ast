{
  "name": "url-ast",
  "version": "2.0.3",
  "description": "High-performance typed URL parser with AST-based analysis, automatic type casting, and route pattern matching for modern web applications",
  "main": "dist/cjs/index.js",
  "module": "dist/mjs/index.js",
  "types": "dist/types/index.d.ts",
  "typings": "dist/types/index.d.ts",
  "type": "module",
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "license": "MIT",
  "author": "Ashu11-A",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AsterFlow/url-ast.git"
  },
  "bugs": {
    "url": "https://github.com/AsterFlow/url-ast/issues"
  },
  "homepage": "https://asterflow.github.io/url-ast",
  "keywords": [
    "url",
    "parser",
    "ast",
    "abstract-syntax-tree",
    "url-parser",
    "url-analyzer",
    "typescript",
    "router",
    "routing",
    "path-parser",
    "query-string",
    "url-pattern",
    "parameter-extraction",
    "type-casting",
    "typed-params",
    "restful",
    "api",
    "high-performance",
    "url-manipulation",
    "dynamic-routes",
    "asterflow",
    "bun"
  ],
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "node": {
        "import": "./dist/mjs/index.js",
        "require": "./dist/cjs/index.js"
      },
      "browser": "./dist/browser/browser.js",
      "import": "./dist/browser/browser.js",
      "require": "./dist/cjs/index.js"
    },
    "./browser": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/browser/browser.js"
    },
    "./wasm/wasm_bg.wasm": "./dist/wasm/wasm_bg.wasm",
    "./package.json": "./package.json"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "benchmark": "bun bench/src/index.ts",
    "dev": "bun run src/index.ts",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage",
    "lint": "eslint -c eslint.config.js --fix",
    "type-check": "tsc --noEmit",
    "build:wasm": "bash scripts/build-wasm.sh",
    "build": "bun run build.ts"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/bun": "latest",
    "cronometro": "^5.3.0",
    "dts-bundle-generator": "^9.5.1",
    "eslint": "^9.39.4",
    "globals": "^16.5.0",
    "typedoc": "^0.28.18",
    "typedoc-plugin-markdown": "^4.11.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.57.2"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}